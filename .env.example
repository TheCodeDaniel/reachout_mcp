# ── Claude AI ─────────────────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Notion ─────────────────────────────────────────────────────────────────────
# Get this from: https://www.notion.so/my-integrations → create integration → copy key
NOTION_API_KEY=your_notion_api_key_here

# Create a database on notion.so, copy its ID from the URL, paste it here.
# Then run setup_notion_db once to create all required columns.
NOTION_DATABASE_ID=

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Gmail: use smtp.gmail.com, port 587, and an App Password (not your regular password)
# Outlook: use smtp.office365.com, port 587
# Get Gmail App Password: https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# The name and address that shows up in the recipient's inbox
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME=Your Name
